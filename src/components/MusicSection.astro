---

<section class="hub-section hub-section--music">
  <div class="hub-section__header">
    <a
      class="hub-section__title group"
      href="https://www.youtube.com/@AlexBonSpace"
      target="_blank"
      rel="noopener noreferrer"
    >
      <h2>{headings[locale]}</h2>
      <span class="hub-section__arrow" aria-hidden="true">→</span>
    </a>
    <p class="hub-section__description">{subtitle}</p>
  </div>

  <div class="music-grid">
    {
      videos.map((video) => (
        <a
          href={`https://www.youtube.com/watch?v=${video.id}`}
          target="_blank"
          rel="noopener noreferrer"
          class="music-card"
        >
          <div class="music-card__thumb">
            <img
              src={`https://img.youtube.com/vi/${video.id}/mqdefault.jpg`}
              alt={video.title}
              loading="lazy"
              width="320"
              height="180"
            />
            <div class="music-card__play" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="32" height="32">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
          <span class="music-card__title">{video.title}</span>
        </a>
      ))
    }
  </div>

  <div class="music-platforms">
    {
      platformLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="music-platforms__link"
          aria-label={link.label}
        >
          <Fragment set:html={link.icon} />
          <span>{link.label}</span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .music-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  @media (max-width: 480px) {
    .music-grid {
      grid-template-columns: 1fr;
      gap: 0.625rem;
    }
  }

  .music-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text-primary);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: transform 0.2s ease;
  }

  .music-card:hover {
    transform: translateY(-3px);
  }

  .music-card__thumb {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    box-shadow: var(--shadow-card);
  }

  .music-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .music-card__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.2s ease;
    color: #fff;
  }

  .music-card:hover .music-card__play {
    opacity: 1;
  }

  .music-card__title {
    font-size: 0.8125rem;
    font-weight: 500;
    text-align: center;
    padding: 0 0.25rem;
  }

  .music-platforms {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
    justify-content: center;
  }

  .music-platforms__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    border: 1.5px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    color: var(--color-text-primary);
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .music-platforms__link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  /* Music section accent: purple/violet to stand out from text sections */
  :global(.hub-section--music) {
    --section-accent: hsl(270, 50%, 55%);
  }
</style>
